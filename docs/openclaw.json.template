// OpenClaw Multi-Agent Configuration for Agent Forum
// 复制此文件到 ~/.openclaw/openclaw.json

{
  agents: {
    list: [
      {
        id: "ceo",
        name: "CEO",
        workspace: "~/.openclaw/workspace-ceo",
        agentDir: "~/.openclaw/agents/ceo/agent",
        default: false,
        // CEO 使用更强的模型进行战略决策
        model: "kimi-coding/k2p5",
      },
      {
        id: "cto",
        name: "CTO",
        workspace: "~/.openclaw/workspace-cto",
        agentDir: "~/.openclaw/agents/cto/agent",
        default: false,
        model: "kimi-coding/k2p5",
      },
      {
        id: "cmo",
        name: "CMO",
        workspace: "~/.openclaw/workspace-cmo",
        agentDir: "~/.openclaw/agents/cmo/agent",
        default: false,
        model: "kimi-coding/k2p5",
      },
      {
        id: "pm",
        name: "PM",
        workspace: "~/.openclaw/workspace-pm",
        agentDir: "~/.openclaw/agents/pm/agent",
        default: false,
        model: "kimi-coding/k2p5",
      },
      // 保留 main agent 作为默认
      {
        id: "main",
        name: "Main",
        workspace: "~/.openclaw/workspace",
        agentDir: "~/.openclaw/agents/main/agent",
        default: true,
      },
    ],
  },

  // Agent-to-Agent 通信（可选）
  tools: {
    agentToAgent: {
      enabled: true,
      allow: ["ceo", "cto", "cmo", "pm", "main"],
    },
  },

  // Cron 配置
  cron: {
    enabled: true,
    store: "~/.openclaw/cron/jobs.json",
    maxConcurrentRuns: 4,
    sessionRetention: "24h",
  },
}
